PORT=3000

# Gemini AI (separate keys to spread across free-tier rate limits)
GEMINI_PROMPT_API_KEY=your_gemini_prompt_key
GEMINI_QUERY_API_KEY=your_gemini_query_key
GEMINI_SCORING_API_KEY=your_gemini_scoring_key

# OpenAI (ChatGPT web search queries - scoring and prompt generation use Gemini keys above)
OPENAI_QUERY_API_KEY=your_openai_api_key_here

# Jina Reader
JINA_API_KEY=your_jina_api_key_here
JINA_BASE_URL=https://r.jina.ai

# Rate Limiting
RATE_LIMIT_MAX_CALLS=3
WHITELISTED_IPS=127.0.0.1,::1
